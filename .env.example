# Database
DATABASE_URL=postgresql://cfp:cfp@localhost:5432/cfp

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Data sources (populated in later phases)
POLYGON_API_KEY=
FRED_API_KEY=
FMP_API_KEY=
HEATSEEKER_BASE_URL=
UNUSUAL_WHALES_API_KEY=

# LLM (Phase 4c+ — agent ensemble)
# Provider switch: "anthropic" (default) or "moonshot"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-32k

# Observability (Langfuse v4 — optional, no-op if unset)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
