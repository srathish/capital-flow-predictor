# Database
DATABASE_URL=postgresql://cfp:cfp@localhost:5432/cfp

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# CORS — comma-separated origins. "*" allows all (dev only).
CORS_ORIGINS_RAW=http://localhost:3000

# API auth — comma-separated bearer tokens accepted on /v1/*.
# Leave empty to disable auth (dev). In prod, set to a single 64-char hex value:
#   API_KEYS_RAW=$(openssl rand -hex 32)
# The FE must send the same value as NEXT_PUBLIC_API_KEY (Vercel env var).
API_KEYS_RAW=

# Rate limit (per identity = api key or IP).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MIN=120
RATE_LIMIT_RUN_PER_HOUR=30

# Freshness thresholds (hours since latest row) used by /v1/health/detailed.
HEALTH_STALE_HOURS_PRICES=36
HEALTH_STALE_HOURS_SIGNALS=48
HEALTH_STALE_HOURS_NEWS=12

# Local-only helper for scripts/smoke_test.sh. Set to one of the API_KEYS_RAW values.
API_KEY=

# Data sources (populated in later phases)
POLYGON_API_KEY=
FRED_API_KEY=
FMP_API_KEY=
HEATSEEKER_BASE_URL=
UNUSUAL_WHALES_API_KEY=

# LLM (Phase 4c+ — agent ensemble)
# Provider switch: "anthropic" (default) or "moonshot"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-32k

# Observability (Langfuse v4 — optional, no-op if unset)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
