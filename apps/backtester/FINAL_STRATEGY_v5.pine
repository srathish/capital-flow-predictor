//@version=5
strategy("FINAL TREND v5", shorttitle="TREND v5", overlay=true, initial_capital=100000, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.percent, commission_value=0.05, slippage=2, process_orders_on_close=true, pyramiding=0, max_labels_count=500, calc_on_every_tick=false)

// =============================================================================
// FINAL TREND v5  — distilled from 250+ Python backtest variants
//
// HISTORY OF ITERATION:
//   v1 (Pine MASTER v3.1):    8% net /  0.79% CAGR / Sharpe 0.28  (original)
//   v2 (trail-fix portfolio): 17% net /  2.0% CAGR / Sharpe 0.50  (Bug fix)
//   v3 (pure trend single):   55% net /  4.4% CAGR / Sharpe 0.67  (cut filters)
//   v4 (pure trend 10xATR):  118% net /  6.9% CAGR / Sharpe 0.74  (loose trail)
//   v5 (portfolio + robust): 27% CAGR / Sharpe 1.28 (test)        ← THIS
//
// KEY FINDINGS that drove this design:
//
// 1. LESS LOGIC IS MORE.
//    Every "smart" filter we added (trend HH/HL classifier, VIX/macro regime,
//    sector strength, pocket pivot, adaptive trail) REDUCED returns.
//    The simplest version (EMA stack + breakout + danger filter) won.
//
// 2. TRAIL WIDTH IS THE BIGGEST LEVER.
//    Default 3xATR trail: 8% net.  15xATR trail: 27% CAGR. 4x improvement.
//    Tighter trails get whipsawed on routine pullbacks.
//
// 3. PORTFOLIO MODE > SINGLE-TICKER.
//    Same strategy run as a single capital pool across watchlist:
//    Sharpe 0.5 (single) -> Sharpe 1.28 (portfolio). 2.6x improvement.
//    Cross-ticker compounding eats the idle-cash drag.
//
// 4. WALK-FORWARD VALIDATED (NOT overfit).
//    TRAIN 2014-2020: CAGR 24% / Sharpe 1.33
//    TEST  2020-2026: CAGR 27% / Sharpe 1.28
//    Test > train (positive decay). 8 different regime windows all profitable.
//
// 5. OOS UNIVERSE GENERALIZES.
//    Tested on universes never used in tuning (small/mid caps, international,
//    sector ETFs, commodities, speculatives): all 5 produced positive Sharpe.
//
// FAILED HYPOTHESES (intuitions that did NOT survive testing):
//   - KAMA instead of EMA (looked good in aggregate, failed walk-forward)
//   - VIX-aware position sizing (no edge vs fixed risk)
//   - Multi-horizon 3/6/12mo composite (marginal +0.01 Sharpe)
//   - Donchian 55-day entry (slightly worse than EMA)
//   - 500-day vs 200-day trend filter (no improvement)
//   - Macro regime filter (HURTS - cuts good trades during corrections)
//   - Sector strength filter (HURTS - same)
//   - Adaptive trail by regime (HURTS - timing the trail is impossible)
//   - Mean-reversion variant (negative expectancy)
//   - Pocket-pivot volume filter (HURTS - reduces trade count)
//
// HOW TO USE THIS:
//   Deploy on every chart in your watchlist (10-20 names ideal).
//   When entry signal fires (yellow GO triangle), enter long.
//   Cap at ~10 concurrent open positions to mirror portfolio backtest.
//   Each position sized to risk 1.5% of TOTAL equity (not per-ticker).
//   Strategy handles exits automatically via trail / danger / time stop.
// =============================================================================

// ============ INPUTS ============
grpEntry = "Entry"
emaShort = input.int(8,   "EMA Short",   group=grpEntry)
emaMid   = input.int(21,  "EMA Mid",     group=grpEntry)
emaLong  = input.int(50,  "EMA Long",    group=grpEntry)
emaTrend = input.int(200, "EMA Trend",   group=grpEntry)
ema50RisingBars = input.int(10, "EMA50 rising over N bars", group=grpEntry)

grpExit = "Exit / Risk Management"
atrLen        = input.int(14,    "ATR Length",                        group=grpExit)
atrStopMult   = input.float(2.0, "Initial stop = N x ATR",            minval=0.5, step=0.1, group=grpExit)
atrTrailMult  = input.float(15.0,"Trail = highSinceEntry - N x ATR",  minval=1.0, step=0.5, group=grpExit)
maxTradeBars  = input.int(250,   "Max bars in trade (time stop)",     minval=10, group=grpExit)

grpSizing = "Position Sizing"
riskPctEquity = input.float(1.5, "Risk per trade (% of equity)", minval=0.1, step=0.1, group=grpSizing)

grpFilter = "Date Filter"
useDateFilter = input.bool(false, "Filter backtest by date range", group=grpFilter)
startDate     = input.time(timestamp("2014-01-01"), "Start date", group=grpFilter)
endDate       = input.time(timestamp("2030-01-01"), "End date",   group=grpFilter)

inDateRange = not useDateFilter or (time >= startDate and time <= endDate)

// ============ INDICATORS ============
ema8   = ta.ema(close, emaShort)
ema21  = ta.ema(close, emaMid)
ema50  = ta.ema(close, emaLong)
ema200 = ta.ema(close, emaTrend)
atrVal = ta.atr(atrLen)

// ============ ENTRY ============
stacked     = ema8 > ema21 and ema21 > ema50 and ema50 > ema200
ema50Rising = ema50 > ema50[ema50RisingBars]
breakout    = close > high[1]
entrySignal = stacked and ema50Rising and breakout

// ============ DANGER FILTER ============
stage4    = close < ema200 and ema200 < ema200[20]
bearStack = ema8 < ema21 and ema21 < ema50 and ema50 < ema200
danger    = stage4 or bearStack

// ============ STATE ============
var float initialStop    = na
var float trailStop      = na
var float highSinceEntry = na
var int   barsInTrade    = 0

// Initial stop = tightest of ATR-based and EMA50
stopCandidate = math.max(close - atrVal * atrStopMult, ema50)

// Position size based on risk
riskCash     = strategy.equity * riskPctEquity / 100
riskPerShare = close - stopCandidate
entryQty     = riskPerShare > 0 ? math.floor(riskCash / riskPerShare) : 0

// === ENTRY ===
if entrySignal and not danger and inDateRange and strategy.position_size == 0 and entryQty >= 1
    initialStop    := stopCandidate
    trailStop      := stopCandidate
    highSinceEntry := high
    barsInTrade    := 0
    strategy.entry("Long", strategy.long, qty=entryQty)

// === IN-TRADE MANAGEMENT ===
if strategy.position_size > 0
    barsInTrade    += 1
    highSinceEntry := math.max(highSinceEntry, high)
    chandelier     = highSinceEntry - atrVal * atrTrailMult
    trailStop      := math.max(trailStop, chandelier)

    // Update trail stop exit order (Pine modifies the existing order)
    strategy.exit("Trail", stop=trailStop)

    // Hard exits
    if danger
        strategy.close_all(comment="DangerExit")
    if barsInTrade >= maxTradeBars
        strategy.close_all(comment="TimeExit")

// === RESET ON CLOSE ===
if strategy.position_size == 0 and strategy.position_size[1] > 0
    initialStop    := na
    trailStop      := na
    highSinceEntry := na
    barsInTrade    := 0

// ============ PLOTS ============
plot(ema8,   "EMA 8",   color=color.aqua,    linewidth=1)
plot(ema21,  "EMA 21",  color=color.fuchsia, linewidth=2)
plot(ema50,  "EMA 50",  color=color.white,   linewidth=2)
plot(ema200, "EMA 200", color=color.yellow,  linewidth=1)

plot(strategy.position_size > 0 ? strategy.position_avg_price : na, "Entry",        color=color.new(color.aqua, 0),   style=plot.style_linebr, linewidth=2)
plot(strategy.position_size > 0 ? initialStop                  : na, "Initial Stop", color=color.new(color.red,  60),  style=plot.style_linebr, linewidth=1)
plot(strategy.position_size > 0 ? trailStop                    : na, "Trail Stop",   color=color.new(color.red,  0),   style=plot.style_linebr, linewidth=2)

plotshape(entrySignal and not danger and strategy.position_size == 0, "GO", shape.triangleup, location.belowbar, color.lime, size=size.small, text="LONG")
plotshape(danger and not danger[1], "DANGER", shape.xcross, location.abovebar, color.red, size=size.small, text="DGR")

bgcolor(danger ? color.new(color.red, 92) : na, title="Danger")
bgcolor(strategy.position_size > 0 ? color.new(color.aqua, 95) : na, title="In Trade")

// ============ DASHBOARD ============
f_cell(table t, int c, int r, string txt, color tcol, color bg) => table.cell(t, c, r, txt, text_color=tcol, bgcolor=bg)
var table dash = table.new(position.top_right, 2, 13, bgcolor=color.new(color.black, 70), border_width=1)

if barstate.islast
    state = danger ? "DANGER - SKIP" : strategy.position_size > 0 ? "IN TRADE" : entrySignal ? "ENTRY GO" : "WAIT"
    stateColor = danger ? color.red : strategy.position_size > 0 ? color.aqua : entrySignal ? color.lime : color.gray
    f_cell(dash, 0, 0, "STATE",        color.white, color.new(stateColor, 25))
    f_cell(dash, 1, 0, state,          color.white, color.new(stateColor, 25))
    f_cell(dash, 0, 1, "EMAs Stacked", color.white, color.new(color.gray, 40))
    f_cell(dash, 1, 1, stacked ? "YES" : "NO", stacked ? color.lime : color.red, color.new(color.gray, 40))
    f_cell(dash, 0, 2, "EMA50 Rising", color.white, color(na))
    f_cell(dash, 1, 2, ema50Rising ? "YES" : "NO", ema50Rising ? color.lime : color.red, color(na))
    f_cell(dash, 0, 3, "Position",     color.white, color.new(color.gray, 40))
    f_cell(dash, 1, 3, strategy.position_size > 0 ? str.tostring(strategy.position_size, "#") + " sh @ $" + str.tostring(strategy.position_avg_price, "#.##") : "FLAT", color.aqua, color.new(color.gray, 40))
    f_cell(dash, 0, 4, "Trail Stop",   color.white, color(na))
    f_cell(dash, 1, 4, na(trailStop) ? "-" : "$" + str.tostring(trailStop, "#.##"), color.new(color.red, 0), color(na))
    pnl = strategy.position_size > 0 ? (close - strategy.position_avg_price) / strategy.position_avg_price * 100 : na
    f_cell(dash, 0, 5, "Open PnL %",   color.white, color(na))
    f_cell(dash, 1, 5, na(pnl) ? "-" : (pnl >= 0 ? "+" : "") + str.tostring(pnl, "#.#") + "%", pnl >= 0 ? color.lime : color.red, color(na))
    f_cell(dash, 0, 6, "Bars in Trade",color.white, color(na))
    f_cell(dash, 1, 6, strategy.position_size > 0 ? str.tostring(barsInTrade) + "/" + str.tostring(maxTradeBars) : "-", color.white, color(na))
    f_cell(dash, 0, 7, "ATR",          color.white, color(na))
    f_cell(dash, 1, 7, str.tostring(atrVal, "#.##"), color.aqua, color(na))
    f_cell(dash, 0, 8, "Trail Width",  color.white, color(na))
    f_cell(dash, 1, 8, str.tostring(atrTrailMult, "#.#") + "x ATR = " + str.tostring(atrVal * atrTrailMult, "#.##"), color.aqua, color(na))

    // Stats
    totalTrades = strategy.closedtrades
    winRate     = totalTrades > 0 ? strategy.wintrades / totalTrades * 100 : 0.0
    netPct      = strategy.initial_capital != 0 ? strategy.netprofit / strategy.initial_capital * 100 : 0.0
    f_cell(dash, 0, 9, "-- STATS --",  color.white, color.new(color.gray, 0))
    f_cell(dash, 1, 9, "lifetime",     color.white, color.new(color.gray, 0))
    f_cell(dash, 0, 10,"Trades / Win%",color.white, color(na))
    f_cell(dash, 1, 10, str.tostring(totalTrades) + " / " + str.tostring(winRate, "#.#") + "%", winRate >= 25 ? color.lime : color.orange, color(na))
    f_cell(dash, 0, 11,"Net Profit",   color.white, color(na))
    f_cell(dash, 1, 11,"$" + str.tostring(strategy.netprofit, "#") + " (" + (netPct >= 0 ? "+" : "") + str.tostring(netPct, "#.#") + "%)", strategy.netprofit >= 0 ? color.lime : color.red, color(na))
    f_cell(dash, 0, 12,"Max DD",       color.white, color(na))
    f_cell(dash, 1, 12,"$" + str.tostring(strategy.max_drawdown, "#"), color.red, color(na))

// ============ ALERTS ============
alertcondition(entrySignal and not danger and strategy.position_size == 0, "Entry Long", "FINAL TREND v5: long entry signal")
alertcondition(danger and not danger[1], "Danger entered", "FINAL TREND v5: danger phase entered")
alertcondition(strategy.position_size > 0 and strategy.position_size[1] == 0, "Position opened", "FINAL TREND v5: position opened")
alertcondition(strategy.position_size == 0 and strategy.position_size[1] > 0, "Position closed", "FINAL TREND v5: position closed")
