# Public — bundled into the client. Set to your deployed FastAPI base URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Server-only — used by RSC fetches if set; falls back to NEXT_PUBLIC_API_BASE_URL.
# Useful if the server-side network needs a different hostname (Railway internal vs public).
# API_BASE_URL=http://api.internal:8000
