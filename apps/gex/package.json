{
  "name": "@cfp/gex",
  "private": true,
  "version": "0.1.0",
  "description": "GEX data pipeline — Heatseeker SSE poller + scheduled briefs + intraday alerts. Migrated from the standalone gexester-vexster repo (now archived).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "smoke": "node src/smoke.js",
    "brief": "node scripts/morning-brief.js",
    "monitor": "node scripts/intraday-monitor.js",
    "scan": "D=$(date +%Y-%m-%d) && node scanner/scripts/scan-day.js --date=$D && node scanner/scripts/refine-picks.js --date=$D --top=10 && node scanner/scripts/daily-report.js --date=$D --discord",
    "schedule": "node scripts/schedule.js",
    "replay": "DATA_DIR=./data/replay node scripts/run-replay.js",
    "plays": "node scripts/plays-tracker.js",
    "plays:brief": "node scripts/plays-tracker.js --brief-only",
    "plays:silent": "node scripts/plays-tracker.js --no-tail",
    "auth:check": "node scripts/auth-preflight.js",
    "ghost:ab": "node scripts/ghost-exit-ab.js",
    "plays:view": "node scripts/plays-view.js",
    "plays:live": "node scripts/plays-view.js --live",
    "grade": "node scripts/grade-universe.js",
    "grade:a": "node scripts/grade-universe.js --min-grade=A",
    "grade:aplus": "node scripts/grade-universe.js --min-grade=A+",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "luxon": "^3.5.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.4",
    "vitest": "^2.1.4"
  }
}
